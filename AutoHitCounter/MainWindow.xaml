<Window x:Class="AutoHitCounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:converters="clr-namespace:AutoHitCounter.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:controls="clr-namespace:AutoHitCounter.Views.Controls"
        xmlns:behaviors="clr-namespace:AutoHitCounter.Behaviors"
        Icon="pack://application:,,,/Assets/icon.ico"
        mc:Ignorable="d"
        Style="{StaticResource DefaultWindowStyle}"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="Auto Hit Counter" Height="720" Width="525">
    <Window.Resources>
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        <system:Double x:Key="FontSizeHeader">15</system:Double>
        <system:Double x:Key="FontSizeBody">13</system:Double>
        <converters:ParentChildMarginConverter x:Key="ParentChildMarginConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:ExpanderArrowConverter x:Key="ExpanderArrowConverter" />
        <xctk:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <controls:TitleBar Grid.Row="0" Title="Auto Hit Counter" />
        <!-- Tool Attachment Info -->
        <Grid Grid.Row="1" Margin="5">
            <TextBlock Text="{Binding AppVer}" />
            <Button x:Name="CheckUpdateButton" Content="Check for Updates"
                    Click="CheckUpdateButton_Click"
                    Margin="5,0,5,-2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
            </Button>
            <TextBlock Text="{Binding AttachedText}"
                       HorizontalAlignment="Right" />
        </Grid>
        <!-- Main Tabs -->
        <TabControl Grid.Row="2" x:Name="MainTabControl">

            <!-- Splits Tab -->
            <TabItem Header="Splits">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*" />
                        <RowDefinition Height="0.3*" />
                        <RowDefinition Height="4*" />
                        <RowDefinition Height="0.6*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8,4,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="GAME"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10"
                                       Foreground="#666666"
                                       Margin="2,0,0,2" />
                            <ComboBox ItemsSource="{Binding Games}"
                                      SelectedItem="{Binding SelectedGame}"
                                      DisplayMemberPath="GameName" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="4,0,4,0">
                            <TextBlock Text="PROFILE"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10"
                                       Foreground="#666666"
                                       Margin="2,0,0,2" />
                            <ComboBox ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding ActiveProfile}"
                                      DisplayMemberPath="Name" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="✎"
                                Command="{Binding OpenProfileEditorCommand}"
                                VerticalAlignment="Center"
                                Width="30"
                                Height="22"
                                FontSize="14"
                                ToolTip="Edit Profile" />
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Splits Header -->
                            <TextBlock FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeHeader}"
                                       Text="Split"
                                       VerticalAlignment="Center"
                                       Margin="10, 0, 0,0" />

                            <TextBlock Grid.Column="1"
                                       Text="Hits"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeHeader}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <TextBlock Grid.Column="2"
                                       Text="Diff"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeHeader}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <TextBlock Grid.Column="3"
                                       Text="PB"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeHeader}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Splits}"
                             SelectedItem="{Binding SelectedSplit}"
                             AlternationCount="2"
                             behaviors:SplitListDragDropBehavior.IsEnabled="True"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <!-- Split List -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="BorderThickness" Value="3,0,0,0" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                    Margin="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="ListBox.AlternationIndex" Value="0">
                                                    <Setter TargetName="Border" Property="Background"
                                                            Value="{StaticResource BackgroundBrush}" />
                                                </Trigger>
                                                <Trigger Property="ListBox.AlternationIndex" Value="1">
                                                    <Setter TargetName="Border" Property="Background" Value="#222222" />
                                                </Trigger>
                                                <!-- Split Colours -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#6683518c" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#B37c4d85" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#9D61A8" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#1A1A1A" />
                                                    <Setter TargetName="Border" Property="BorderBrush"
                                                            Value="Transparent" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>


                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   VerticalAlignment="Center"
                                                   Margin="{Binding Type,
                                                       Converter={StaticResource ParentChildMarginConverter}}" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding NumOfHits}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Diff}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding PersonalBest}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <Grid Margin="10,6,10,4">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition
                                                                Binding="{Binding DataContext.Settings.IsShowNotesEnabled,
                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Value="True" />
                                                            <Condition Binding="{Binding IsParent}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 FontSize="11"
                                                 Foreground="#777"

                                                 Padding="2">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Cursor" Value="IBeam" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="Background" Value="#1a1a30" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Setter Property="BorderBrush" Value="#333366" />
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="Text" Value="" />
                                                                <Condition Property="IsFocused" Value="False" />
                                                            </MultiTrigger.Conditions>
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <VisualBrush AlignmentX="Left" AlignmentY="Top"
                                                                            Stretch="None">
                                                                        <VisualBrush.Visual>
                                                                            <TextBlock Text="Add notes..."
                                                                                    Foreground="#444"
                                                                                    FontSize="11"
                                                                                    FontStyle="Italic"
                                                                                    Margin="4,2,0,0" />
                                                                        </VisualBrush.Visual>
                                                                    </VisualBrush>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </MultiTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="3">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunComplete}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button Content="- Hit" Margin="5,0,0,5"
                                    Height="23" VerticalAlignment="Bottom"
                                    Command="{Binding DecrementHitCommand}" />
                            <Button Content="+ Hit" Margin="5,0,0,5"
                                    Height="23" VerticalAlignment="Bottom"
                                    Command="{Binding IncrementHitCommand}" />
                            <Button Content="← Prev Split" Margin="5,0,0,5"
                                    Height="23" VerticalAlignment="Bottom"
                                    Command="{Binding PrevSplitCommand}" />
                            <Button Content="Next Split →" Margin="5,0,0,5"
                                    Height="23" VerticalAlignment="Bottom"
                                    Command="{Binding AdvanceSplitCommand}" />
                            <Button Content="Reset" Margin="5,0,0,5"
                                    Height="23" VerticalAlignment="Bottom"
                                    Command="{Binding ResetCommand}" />
                            <!-- Not sure what to do with this -->
                            <Button Content="Run Notes" Margin="5,0,0,5"
                                    Height="23" VerticalAlignment="Bottom" />
                            
                            <!-- Consider Adding a checkbox for notes Column or something, ask shilkey, 
                            also consider moving the igt elsewhere for buttons space -->
                            
                        </StackPanel>
                        <!-- Potentially turn this into a popup window -->
                        <StackPanel Visibility="{Binding IsRunComplete, Converter={StaticResource BoolToVisConverter}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="✓ Run Complete"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#00CC66"
                                       HorizontalAlignment="Center" Margin="0,4,0,6" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <TextBlock Text="Total Hits: " Foreground="#999" />
                                <TextBlock Text="{Binding TotalHits}" Foreground="White" Margin="0,0,12,0" />
                                <TextBlock Text="PB: " Foreground="#999" />
                                <TextBlock Text="{Binding TotalPb}" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Mark as PB" Margin="4,0" />
                                <Button Content="Reset" Margin="4,0" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,5,5"
                                   Text="{Binding InGameTimeFormatted}" />
                    </Grid>

                </Grid>
            </TabItem>

            <!-- Hotkeys Tab -->
            <TabItem Header="Hotkeys">
                <controls:HotkeysTab DataContext="{Binding Hotkeys}" />
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <controls:SettingsTab DataContext="{Binding Settings}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>