<Window x:Class="AutoHitCounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:converters="clr-namespace:AutoHitCounter.Converters"
        xmlns:controls="clr-namespace:AutoHitCounter.Views.Controls"
        xmlns:behaviors="clr-namespace:AutoHitCounter.Behaviors"
        Icon="pack://application:,,,/Assets/icon.ico"
        mc:Ignorable="d"
        Style="{StaticResource DefaultWindowStyle}"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="Auto Hit Counter" Height="720" Width="525">
    <Window.Resources>
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        <system:Double x:Key="FontSizeHeader">15</system:Double>
        <system:Double x:Key="FontSizeBody">13</system:Double>
        <converters:ParentChildMarginConverter x:Key="ParentChildMarginConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:LockIconConverter x:Key="LockIconConverter" />
        <converters:LockTooltipConverter x:Key="LockTooltipConverter" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#9D61A8" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
        <converters:AttemptCountColorConverter x:Key="AttemptCountColorConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="*"  />
        </Grid.RowDefinitions>
        <controls:TitleBar Grid.Row="0" Title="Auto Hit Counter" />
        <!-- Tool Attachment Info -->
        <Grid Grid.Row="1" Margin="5,3,8,3">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppVer}" Foreground="#666" FontSize="11" VerticalAlignment="Center" />
                <Button x:Name="CheckUpdateButton" Content="Check for Updates"
                        Margin="8,0,0,0" Height="20" FontSize="11"
                        VerticalAlignment="Center" />
                <!-- Return this later → Click="CheckUpdateButton_Click" -->
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#D32F2F" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAttached}" Value="True">
                                    <Setter Property="Fill" Value="#4CAF50" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding AttachedText}" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
        <!-- Main Tabs -->
        <TabControl Grid.Row="2" x:Name="MainTabControl">

            <!-- Splits Tab -->
            <TabItem Header="Splits">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*" />
                        <RowDefinition Height="0.3*" />
                        <RowDefinition Height="4*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0.6*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8,4,8,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="GAME" FontFamily="{StaticResource AppFont}" FontSize="10"
                                       Foreground="#666666" Margin="2,0,0,2" />
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Track"
                                        Command="{Binding TrackGameCommand}"
                                        Height="22"
                                        Margin="4,0,0,0"
                                        ToolTip="{Binding TrackingText}" />
                                <ComboBox ItemsSource="{Binding Games}"
                                          SelectedItem="{Binding SelectedGame}"
                                          DisplayMemberPath="GameName" />
                            </DockPanel>
                            <TextBlock Text="{Binding TrackingText}"
                                       FontSize="9" Foreground="#555555" Margin="2,1,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                            <TextBlock Text="PROFILE"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10"
                                       Foreground="#666666"
                                       Margin="2,0,0,2" />
                            <ComboBox ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding ActiveProfile}"
                                      DisplayMemberPath="Name" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="0,1,-2,0">
                            <!-- Edit Profile Button -->
                            <Button Content="✎"
                                    Command="{Binding OpenProfileEditorCommand}"
                                    Width="30" Height="22.1"
                                    FontSize="14" Padding="0,0,0.5,2.7"
                                    ToolTip="Edit Profile" />
                            <!-- Lock Splits Button -->
                            <Button Content="{Binding IsUnlocked, Converter={StaticResource LockIconConverter}}"
                                    Command="{Binding ToggleLockCommand}"
                                    Width="30" Height="22.1"
                                    FontSize="13" Padding="0,0,0,0"
                                    Margin="4,0,0,0"
                                    ToolTip="{Binding IsUnlocked, Converter={StaticResource LockTooltipConverter}}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <Grid Margin="{Binding IsSplitListScrollbarVisible, Converter={StaticResource ScrollbarVisibleToMarginConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Split header + current/total -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource AppFont}"
                                           FontSize="{StaticResource FontSizeHeader}"
                                           Text="Split"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />

                                <!-- Splitter -->
                                <Rectangle Width="1" Height="12" Fill="#444" Margin="7,0,7,0"
                                           VerticalAlignment="Center">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunComplete}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>

                                <!-- (Split/Total) -->
                                <TextBlock FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunComplete}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="(" /><Run Text="{Binding CurrentSplitNumber, Mode=OneWay}" ToolTip="Current Split" />
                                    <Run Text="/" />
                                    <Run Text="{Binding TotalSplitCount, Mode=OneWay}" ToolTip="Total Splits" /><Run Text=")" />
                                </TextBlock>

                                <!-- Splitter -->
                                <Rectangle Width="1" Height="12" Fill="#444" Margin="7,0,7,0"
                                           VerticalAlignment="Center">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunComplete}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>

                                <!-- Attempts count -->
                                <TextBlock FontSize="12"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"
                                           Text="{Binding AttemptCount, StringFormat='#{0}'}"
                                           ToolTip="Double Click to edit attempts count"
                                           Foreground="{Binding AttemptCount, Converter={StaticResource AttemptCountColorConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingAttempts}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding EditAttemptsCommand}" />
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <TextBox x:Name="AttemptsBox"
                                         FocusVisualStyle="{x:Null}"
                                         CaretBrush="White"
                                         SelectionBrush="#9D61A8"
                                         TextAlignment="Center"
                                         FontSize="11"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding AttemptCount, Mode=OneWay}"
                                         KeyDown="AttemptsBox_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Setter Property="Foreground" Value="#DDDDDD" />
                                            <Setter Property="Padding" Value="3,1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingAttempts}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>

                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Reset Attempt count button -->
                                <Button FontFamily="Segoe MDL2 Assets" Content="&#xE72C;" FontSize="12" Height="21" Width="24"
                                        Margin="7,0,0,0"
                                        VerticalAlignment="Center"
                                        ToolTip="Reset attempts count"
                                        Click="ResetAttempts_Click" />
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="Hits"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeHeader}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <TextBlock Grid.Column="2"
                                       Text="Diff"
                                       Margin="0,0,7,0"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeHeader}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <TextBlock Grid.Column="3"
                                       Text="PB"
                                       Margin="0,0,8,0"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeHeader}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ListBox x:Name="SplitListBox" 
                             Grid.Row="2" 
                             ItemsSource="{Binding Splits}"
                             SelectedItem="{Binding SelectedSplit}"
                             AlternationCount="2"
                             behaviors:SplitListDragDropBehavior.IsEnabled="{Binding IsUnlocked}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.ScrollChanged="SplitList_ScrollChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <!-- Context Menu -->
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Splits"
                                          Command="{Binding PlacementTarget.DataContext.OpenProfileEditorCommand,
                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Rename"
                                          Command="{Binding PlacementTarget.DataContext.RenameSelectedSplitCommand,
                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Save Notes"
                                          Command="{Binding PlacementTarget.DataContext.SaveNotesCommand,
                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Reset Split Hits"
                                          Command="{Binding PlacementTarget.DataContext.ResetSelectedSplitHitsCommand,
                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Edit PB"
                                          Command="{Binding PlacementTarget.DataContext.EditSplitPbCommand,
                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Clear All PBs"
                                          Command="{Binding PlacementTarget.DataContext.ClearTotalPbCommand,
                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                
                                
                                
                            </ContextMenu>
                        </ListBox.ContextMenu>

                        <!-- Split List -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="MouseDoubleClick" Handler="SplitItem_DoubleClick" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="BorderThickness" Value="4,0,0,0" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                    Margin="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="ListBox.AlternationIndex" Value="0">
                                                    <Setter TargetName="Border" Property="Background"
                                                            Value="{StaticResource BackgroundBrush}" />
                                                </Trigger>
                                                <Trigger Property="ListBox.AlternationIndex" Value="1">
                                                    <Setter TargetName="Border" Property="Background" Value="#222222" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#6683518c" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#c47fd4" />
                                                    <Setter TargetName="Border" Property="Background" Value="#B37c4d85" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#1A1A1A" />
                                                    <Setter TargetName="Border" Property="BorderBrush"
                                                            Value="Transparent" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Drag handle -->
                                        <Grid Grid.Column="0">
                                            <TextBlock Text="⋮⋮"
                                                       Cursor="Hand"
                                                       FontSize="11"
                                                       Foreground="#888"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0"
                                                       HorizontalAlignment="Left">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition
                                                                        Binding="{Binding DataContext.IsUnlocked,
                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                        Value="True" />
                                                                    <Condition
                                                                        Binding="{Binding IsMouseOver,
                            RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                        Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Name column -->
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       VerticalAlignment="Center"
                                                       Margin="{Binding Type, Converter={StaticResource ParentChildMarginConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <!-- In-line Rename box -->
                                            <TextBox x:Name="RenameBox"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="{StaticResource AppFont}"
                                                     FontSize="{StaticResource FontSizeBody}"
                                                     VerticalAlignment="Center"
                                                     Margin="{Binding Type, Converter={StaticResource ParentChildMarginConverter}}"
                                                     KeyDown="RenameBox_KeyDown">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox"
                                                           BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Background"
                                                                Value="{StaticResource BackgroundBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                        
                                        <!-- Hit Count -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding NumOfHits}"
                                                   Foreground="{Binding HitsBrush}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Diff -->
                                        <TextBlock Grid.Column="2"
                                                   
                                                   Text="{Binding Diff}"
                                                   Foreground="{Binding DiffBrush}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- PB -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding PersonalBest, Mode=OneWay}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsParent}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEditingPb}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Grid.Column="3" x:Name="PbBox"
                                                 Text="{Binding PersonalBest, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Width="50"
                                                 KeyDown="PbBox_KeyDown">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Setter Property="Padding" Value="3,1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingPb}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        
                                        <!-- Context Menu Indicator -->
                                        <TextBlock Grid.Column="3"
                                                   Text="⋯"
                                                   MouseDown="SplitContextDots_MouseDown"
                                                   Cursor="Hand"
                                                   FontSize="13"
                                                   Foreground="#888"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0"
                                                   ToolTip="Right click for options">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition
                                                                    Binding="{Binding IsMouseOver,
                                RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                    Value="True" />
                                                                <Condition Binding="{Binding IsParent}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <Grid Margin="10,4,10,6">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition
                                                                Binding="{Binding DataContext.Settings.IsShowNotesEnabled,
                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Value="True" />
                                                            <Condition Binding="{Binding IsParent}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <Border BorderThickness="2,0,0,0" BorderBrush="#3d3040" Padding="6,2">
                                            <Grid>
                                                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         FontSize="11"
                                                         Foreground="#999"
                                                         Padding="2">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Setter Property="BorderThickness" Value="0" />
                                                            <Setter Property="Cursor" Value="IBeam" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsFocused" Value="True">
                                                                    <Setter Property="Background" Value="#1c1424" />
                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                    <Setter Property="BorderBrush" Value="#5a3d63" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBlock Text="Add notes..."
                                                           FontSize="11" FontStyle="Italic"
                                                           Foreground="#555"
                                                           Margin="4,2,0,0"
                                                           IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Notes}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <!-- Total Hits Row -->
                    <Border Grid.Row="3" BorderBrush="#333333" BorderThickness="0,1,0,0"
                            Visibility="{Binding HasSplits, Converter={StaticResource BoolToVisConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Splits.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TotalSplitCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid Margin="{Binding IsSplitListScrollbarVisible, Converter={StaticResource ScrollbarVisibleToMarginConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Total"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"
                                       Margin="30,0,0,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TotalHits}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{Binding TotalHitsBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Margin="0,0,4,0"
                                       Text="{Binding TotalDiff}"
                                       Foreground="#888"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3"
                                       Margin="0,0,8,0"
                                       Text="{Binding TotalPb}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="#909090"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                        

                    <Grid Grid.Row="4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom" Margin="5,0,0,5">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunComplete}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button Content="- Hit" Width="50" Height="24"
                                    Command="{Binding DecrementHitCommand}" />
                            <Button Content="+ Hit" Width="50" Height="24" Margin="3,0,0,0"
                                    Command="{Binding IncrementHitCommand}" />
                            <Rectangle Width="1" Height="16" Fill="#444" Margin="8,0" VerticalAlignment="Center" />
                            <Button Content="← Prev" Height="24" Margin="0,0,3,0"
                                    Command="{Binding PrevSplitCommand}" />
                            <Button Content="Next →" Height="24" Margin="0,0,3,0"
                                    Command="{Binding AdvanceSplitCommand}" />
                            <Rectangle Width="1" Height="16" Fill="#444" Margin="8,0" VerticalAlignment="Center" />
                            <Button Content="Reset" Height="24"
                                    Command="{Binding ResetCommand}" Margin="0,0,3,0" />
                            <Rectangle Width="1" Height="16" Fill="#444" Margin="8,0" VerticalAlignment="Center" />
                            <Button Content="Clear PB" Height="24"
                                    Command="{Binding ClearTotalPbCommand}" />
                            
                        </StackPanel>
                        <!-- Potentially turn this into a popup window -->
                        <StackPanel Visibility="{Binding IsRunComplete, Converter={StaticResource BoolToVisConverter}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="✓ Run Complete"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#00CC66"
                                       HorizontalAlignment="Center" Margin="0,4,0,6" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <TextBlock Text="Total Hits: " Foreground="#999" />
                                <TextBlock Text="{Binding TotalHits}" Foreground="White" Margin="0,0,12,0" />
                                <TextBlock Text="PB: " Foreground="#999" />
                                <TextBlock Text="{Binding TotalPb}" Foreground="White" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Mark as PB" Margin="4,0"
                                        Command="{Binding SetPbCommand}" />
                                <Button Content="Reset" Margin="4,0"
                                        Command="{Binding ResetCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal"
                                    Margin="0,0,5,5">
                            <TextBlock Text="IGT"
                                       FontSize="12"
                                       Foreground="#888"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="{Binding InGameTimeFormatted}"
                                       FontFamily="JetBrains Mono"
                                       FontSize="16"
                                       Foreground="#c47fd4"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </TabItem>

            <TabItem Header="Hotkeys">
                <controls:HotkeysTab DataContext="{Binding Hotkeys}" />
            </TabItem>

            <TabItem Header="Settings">
                <controls:SettingsTab DataContext="{Binding Settings}" />
            </TabItem>
        </TabControl>
        <Button Content="Help"
        Grid.Row="2"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="0,2,3,0"
        Height="25" Width="60" FontSize="12"
        Panel.ZIndex="1"
        Click="HelpButton_Click" />
    </Grid>
</Window>