<UserControl x:Class="AutoHitCounter.Views.Controls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="30"
             >
    <Border Background="{DynamicResource TitleBarBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Source="pack://application:,,,/Assets/icon.ico"
                   Width="16" Height="16"
                   Margin="5,0,5,0"
                   VerticalAlignment="Center" />

            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TitleTextBrush}" 
                       />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Width="46" Height="30" Click="MinimizeButton_Click"
                        Style="{DynamicResource TitleBarButtonStyle}">
                    <TextBlock Text="—" Foreground="{DynamicResource TitleTextBrush}" />
                </Button>
                <Button x:Name="MaximizeButton" Width="46" Height="30" Click="MaximizeButton_Click"
                        Style="{DynamicResource TitleBarButtonStyle}">
                    <TextBlock Text="☐" Foreground="{DynamicResource TitleTextBrush}" />
                </Button>
                <Button Width="46" Height="30" Click="CloseButton_Click"
                        Style="{DynamicResource TitleBarCloseButtonStyle}">
                    <TextBlock Text="✕" Foreground="{DynamicResource TitleTextBrush}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>