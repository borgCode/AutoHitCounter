<UserControl x:Class="AutoHitCounter.Views.Controls.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AutoHitCounter.Converters"
             xmlns:enums="clr-namespace:AutoHitCounter.Enums"
             mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <StackPanel Margin="0,0,0,5">
            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="5">
                <StackPanel>
                    <TextBlock Text="General Settings" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">

                        <TextBlock Text="Theme:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <ComboBox ItemsSource="{Binding ThemeModes}"
                                  SelectedItem="{Binding ThemeMode}"
                                  Width="120" Margin="0,0,10,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Notes:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <ComboBox ItemsSource="{Binding NotesDisplayModes}"
                                  SelectedItem="{Binding NotesDisplayMode}"
                                  Width="120" Margin="0,0,10,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <CheckBox Content="Always On Top"
                                  IsChecked="{Binding IsAlwaysOnTopEnabled}"
                                  Margin="0,0,5,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Separator Margin="0,0,0,10" />

            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="5">
                <StackPanel>
                    <TextBlock Text="Overlay Settings" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Left" />


                    <Button Content="Open Overlay Settings"
                            Command="{Binding OpenOverlaySettingsCommand}"
                            VerticalAlignment="Center"
                            MaxWidth="250"
                            Margin="0,5,0,5"
                            Height="50">
                    </Button>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="5">
                <StackPanel>
                    <TextBlock Text="Game Settings" FontWeight="Bold" Margin="0,0,0,10" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Game" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ComboBox ItemsSource="{Binding GameTitles}"
                                  SelectedItem="{Binding SelectedSettingsGame}"
                                  Width="160">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSettingsGame}"
                                                 Value="{x:Static enums:GameTitle.EldenRing}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="No Logo" IsChecked="{Binding ErNoLogo}" Margin="0, 0, 5, 0" />
                            <CheckBox Content="Stutter Fix" IsChecked="{Binding ERStutterFix}" Margin="0, 0, 5, 0" />
                            <CheckBox Content="Disable Achievements" IsChecked="{Binding ERDisableAchievements}"
                                      Margin="0, 0, 5, 0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSettingsGame}"
                                                 Value="{x:Static enums:GameTitle.DarkSouls3}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="No Logo" IsChecked="{Binding DS3NoLogo}" Margin="0, 0, 5, 0" />
                            <CheckBox Content="Stutter Fix" IsChecked="{Binding DS3StutterFix}" Margin="0, 0, 5, 0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSettingsGame}"
                                                 Value="{x:Static enums:GameTitle.Sekiro}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="No Logo" IsChecked="{Binding SKNoLogo}" Margin="0, 0, 5, 0" />
                            <CheckBox Content="No Tutorials" IsChecked="{Binding SKNoTutorials}" Margin="0, 0, 5, 0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSettingsGame}"
                                                 Value="{x:Static enums:GameTitle.DarkSouls2}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="No Baby Jump" IsChecked="{Binding DS2NoBabyJump}" Margin="0, 0, 5, 0" />
                            <CheckBox Content="Skip Credits" IsChecked="{Binding DS2SkipCredits}" Margin="0, 0, 5, 0" />
                            <CheckBox Content="Disable Double Click" IsChecked="{Binding DS2DisableDoubleClick}"
                                      Margin="0, 0, 5, 0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Height" Value="60" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExternalIntegrationEnabled}"
                                         Value="True">
                                <Setter Property="Height" Value="190" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="External Integration" FontWeight="Bold" Margin="0,0,0,5"
                               HorizontalAlignment="Left" />
                    <StackPanel>
                        <StackPanel Margin="0,5,0,0">
                            <StackPanel Margin="0,5,0,5" Orientation="Horizontal">
                                <CheckBox Content="Enable Integration"
                                          IsChecked="{Binding IsExternalIntegrationEnabled}"
                                          Margin="0,0,10,0" />
                                <StackPanel>
                                    <Border
                                        Background="#3498db"
                                        CornerRadius="10"
                                        Width="12"
                                        Height="12"
                                        Margin="-3,3,0,0"
                                        VerticalAlignment="Center"
                                        ToolTipService.InitialShowDelay='100'>
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <StackPanel>
                                                    <TextBlock Foreground="{DynamicResource UnlockedToolTipTextBrush}"
                                                               FontSize="11" TextWrapping="Wrap"
                                                               MaxWidth="240"
                                                               Text="If enabled, this service will send a POST request&#x0a;to the URI provided with data about the current hit." />
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Text="i"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="10" />
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExternalIntegrationEnabled}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <StackPanel Margin="0,0,0,5">
                                    <Label Content="External URI:" />
                                    <Grid Width="430">
                                        <TextBox
                                            Text="{Binding ExternalIntegrationEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="e.g. http://localhost:3000/hits, https://your.app"
                                                   FontSize="11" FontStyle="Italic" Foreground="#777"
                                                   Margin="12,0,0,0" VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExternalIntegrationEndpoint}"
                                                                     Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ExternalIntegrationEndpoint}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,5">
                                    <Label Content="Runner ID:" />
                                    <Grid Width="430">
                                        <TextBox
                                            Text="{Binding ExternalIntegrationEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock
                                            Text="In case external services requires an identifier to manage multiple users."
                                            FontSize="11" FontStyle="Italic" Foreground="#777"
                                            Margin="12,0,0,0" VerticalAlignment="Center"
                                            IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExternalIntegrationUserId}"
                                                                     Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ExternalIntegrationUserId}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>