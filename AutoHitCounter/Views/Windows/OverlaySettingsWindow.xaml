<Window x:Class="AutoHitCounter.Views.Windows.OverlaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:controls="clr-namespace:AutoHitCounter.Views.Controls"
        Style="{StaticResource DefaultWindowStyle}"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="Overlay Settings"
        Width="920" Height="700"
        MinWidth="920" MinHeight="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#2a2a2a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="Margin" Value="0,0,0,10" />

        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#777777" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="140" />
        </Style>

        <Style x:Key="ColorRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="Separator" TargetType="Separator">
            <Setter Property="Background" Value="#2a2a2a" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>
        <Style TargetType="{x:Type xctk:ColorPicker}">
            <Setter Property="Background" Value="#2d2d2d" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="BorderBrush" Value="#444444" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0" Title="Overlay Settings" />

        <!-- Profile Bar -->
        <Border Grid.Row="1" BorderBrush="#2a2a2a" BorderThickness="0,0,0,1" Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Profile:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,0"
                           FontSize="11" />
                <ComboBox ItemsSource="{Binding ProfileNames}"
                          SelectedItem="{Binding SelectedProfileName}"
                          Width="160" FontSize="11" Margin="0,0,8,0" />
                <Button Content="New" Command="{Binding NewProfileCommand}" FontSize="11" Padding="8,2"
                        Margin="0,0,4,0" />
                <Button Content="Rename" Command="{Binding RenameProfileCommand}" FontSize="11" Padding="8,2"
                        Margin="0,0,4,0" />
                <Button Content="Delete" Command="{Binding DeleteProfileCommand}" FontSize="11" Padding="8,2"
                        Margin="0,0,4,0" />
                <Button Content="Import" Command="{Binding ImportProfileCommand}" FontSize="11" Padding="8,2"
                        Margin="0,0,4,0" />
                <Button Content="Export" Command="{Binding ExportProfileCommand}" FontSize="11" Padding="8,2" />
            </StackPanel>
        </Border>

        <!-- Focus outline -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                BorderThickness="1" IsHitTestVisible="False" Panel.ZIndex="99"
                CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Value="True">
                            <Setter Property="BorderBrush" Value="#4a2d52" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2" Margin="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL - Layout -->
            <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,5,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="LAYOUT" Style="{StaticResource PanelHeader}" />

                        <CheckBox Content="Show Title" IsChecked="{Binding ShowTitle}" Margin="0,2,0,2" />
                        <CheckBox Content="Show Diff" IsChecked="{Binding ShowDiff}" Margin="0,2,0,2" />
                        <CheckBox Content="Show PB" IsChecked="{Binding ShowPb}" Margin="0,2,0,2" />
                        <CheckBox Content="Show IGT" IsChecked="{Binding ShowIgt}" Margin="0,2,0,2" />
                        <CheckBox Content="Show Attempts" IsChecked="{Binding ShowAttempts}" Margin="0,2,0,2" />
                        <CheckBox Content="Show Progress" IsChecked="{Binding ShowProgress}" Margin="0,2,0,2" />
                        <CheckBox Content="Show Distance PB" IsChecked="{Binding ShowDpbHighlight}" Margin="0,2,0,2" />
                        <CheckBox Content="Show Footer Totals" IsChecked="{Binding ShowFooterTotals}" Margin="0,2,0,2" />
                        <CheckBox Content="Show Run Complete" IsChecked="{Binding ShowRunComplete}" Margin="0,2,0,2" />
                        <CheckBox Content="Table Mode" IsChecked="{Binding TableMode}" Margin="0,2,0,2" />
                        <CheckBox Content="PB Color Matches Hit" IsChecked="{Binding PbMatchesHit}" Margin="0,2,0,2" />

                        <Separator Style="{StaticResource Separator}" />
                        <TextBlock Text="SPLITS" Style="{StaticResource SectionLabel}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Prev Splits" Style="{StaticResource FieldLabel}" Width="80" />
                            <xctk:IntegerUpDown Value="{Binding PrevSplits}" Minimum="1" Maximum="50" Width="55" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Next Splits" Style="{StaticResource FieldLabel}" Width="80" />
                            <xctk:IntegerUpDown Value="{Binding NextSplits}" Minimum="1" Maximum="50" Width="55" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" />
                        <TextBlock Text="DIMENSIONS" Style="{StaticResource SectionLabel}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Width" Style="{StaticResource FieldLabel}" Width="80" />
                            <xctk:IntegerUpDown Value="{Binding OverlayWidth}" Minimum="100" Maximum="5000" Width="55" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Max Height" Style="{StaticResource FieldLabel}" Width="80" />
                            <xctk:IntegerUpDown Value="{Binding OverlayHeight}" Minimum="100" Maximum="5000" Width="55" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Row Height" Style="{StaticResource FieldLabel}" Width="80" />
                            <xctk:IntegerUpDown Value="{Binding RowHeight}" Minimum="16" Maximum="60" Width="55" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" />
                        <TextBlock Text="BACKGROUND OPACITY" Style="{StaticResource SectionLabel}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Slider Value="{Binding BackgroundOpacity, Delay=400}" Minimum="0" Maximum="1"
                                    Width="110" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding BackgroundOpacity, StringFormat={}{0:F2}}"
                                       Foreground="#888888" FontSize="11" Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" />
                        <TextBlock Text="CUSTOM CSS" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="Overrides all other overlay settings" FontSize="10" FontStyle="Italic"
                                   Foreground="#878686" Margin="0,-4,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBox Text="{Binding CustomCss, UpdateSourceTrigger=PropertyChanged}"
                                     Height="250"
                                     Width="150"
                                     AcceptsTab="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- CENTER PANEL - Colors -->
            <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,5,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="-6,0,-6,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <TextBlock Text="STYLING" Style="{StaticResource PanelHeader}" />
                            <Border
                                Background="#3498db"
                                CornerRadius="10"
                                Width="12"
                                Height="12"
                                Margin="5,-6,0,0"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay='100'>
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="#9D61A8" VerticalAlignment="Center" />
                                                <TextBlock Text=" Colour Formatting" FontWeight="SemiBold"
                                                           Foreground="#9D61A8" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Foreground="#bbbbbb" FontSize="11" TextWrapping="Wrap"
                                                       MaxWidth="240"
                                                       Text="Adjust the colours to your liking here.&#x0a;&#x0a;The preview box supports CSS3 through CSS5 - named colours, hex, rgb(), hsl(), hwb(), lab(), lch(), oklab(), oklch(), color-mix(), and relative colours.&#x0a;&#x0a;You can use #00000000 or rgba(0, 0, 0, 0) to make any element fully transparent." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="i"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           FontSize="10" />
                            </Border>
                        </StackPanel>

                        <TextBlock Text="TITLE" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Title Text" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding TitleColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding TitleColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" Margin="0,0,10,0" />

                        <TextBlock Text="HEADER" Style="{StaticResource SectionLabel}" />
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Header Text" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding HeaderTextColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding HeaderTextColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" Margin="0,0,10,0" />

                        <TextBlock Text="ATTEMPTS COUNTER" Style="{StaticResource SectionLabel}" />
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="When Zero" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding AttemptsZeroColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding AttemptsZeroColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="When Above Zero" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding AttemptsActiveColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding AttemptsActiveColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" Margin="0,0,10,0" />

                        <TextBlock Text="SPLITS" Style="{StaticResource SectionLabel}" />

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Group Name" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding GroupNameColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding GroupNameColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Split Name" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding SplitNameColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding SplitNameColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Split Name (Not Cleared)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding SplitNameOnHitColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding SplitNameOnHitColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Split Name (Cleared)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding SplitNameOnHitlessColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding SplitNameOnHitlessColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Hits (Current)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding HitsCurrentColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding HitsCurrentColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Hits (Not Cleared)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding HitsActiveColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding HitsActiveColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Hits (Cleared)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding HitsClearedColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding HitsClearedColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Diff (More than PB)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding DiffPosColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding DiffPosColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Diff (Less Than PB)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding DiffNegColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding DiffNegColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Diff (No Difference)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding DiffZeroColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding DiffZeroColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="PB Column" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle Fill="{Binding PbColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding PbColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Row (Not Cleared)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding RowHitColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding RowHitColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Row (Cleared)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding RowClearedColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding RowClearedColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Current Split" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding CurrentSplitColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding CurrentSplitColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Current Split Banner" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding CurrentSplitBorderColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding CurrentSplitBorderColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Current Split (Hit)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding CurrentSplitHitColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding CurrentSplitHitColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Current Split Banner (Hit)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding CurrentSplitHitBorderColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding CurrentSplitHitBorderColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Distance PB Banner" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding DpbHighlightColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding DpbHighlightColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Alternating Split Color" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding AlternatingRows, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding AlternatingRows, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" Margin="0,0,10,0" />

                        <TextBlock Text="FOOTER" Style="{StaticResource SectionLabel}" />

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Hits (When Zero)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding FooterHitsCurrentColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding FooterHitsCurrentColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Hits (When Not Zero)" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding FooterHitFontColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding FooterHitFontColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>

                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="PB Column" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding FooterPbFontColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding FooterPbFontColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>


                        <Separator Style="{StaticResource Separator}" Margin="0,0,10,0" />
                        <TextBlock Text="IN-GAME TIME" Style="{StaticResource SectionLabel}" />
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="In-Game Time" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle Fill="{Binding IgtColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding IgtColor, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" Margin="0,0,10,0" />
                        <TextBlock Text="RUN COMPLETE" Style="{StaticResource SectionLabel}" />
                        <StackPanel Style="{StaticResource ColorRow}">
                            <TextBlock Text="Completion Banner" Style="{StaticResource FieldLabel}" />
                            <Border Width="24" Height="22" BorderBrush="#444" BorderThickness="1" Margin="0,0,4,0">
                                <Rectangle
                                    Fill="{Binding RunCompleteBannerColor, Converter={StaticResource StringToBrushConverter}}" />
                            </Border>
                            <TextBox Text="{Binding RunCompleteBannerColor, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT PANEL - Text -->
            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="TITLE" Style="{StaticResource PanelHeader}" />

                        <TextBlock Text="TEXT" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding TitleText, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 Margin="0,0,0,8" Width="230" HorizontalAlignment="Left" />

                        <TextBlock Text="FONT FAMILY" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding TitleFontFamily}"
                                  Margin="0,0,0,8"
                                  FontSize="11" Width="230" HorizontalAlignment="Left">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="SIZE" Style="{StaticResource SectionLabel}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}" Width="90" />
                            <xctk:IntegerUpDown Value="{Binding TitleFontSize}" Minimum="2" Maximum="64" Width="55" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" />

                        <TextBlock Text="HEADER TEXT" Style="{StaticResource PanelHeader}" />

                        <TextBlock Text="FONT FAMILY" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding HeaderFontFamily}"
                                  Margin="0,0,0,8"
                                  FontSize="11" Width="230" HorizontalAlignment="Left">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="SIZE" Style="{StaticResource SectionLabel}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}" Width="90" />
                            <xctk:IntegerUpDown Value="{Binding HeaderFontSize}" Minimum="2" Maximum="64" Width="55" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" />

                        <TextBlock Text="SPLITS TEXT" Style="{StaticResource PanelHeader}" />

                        <TextBlock Text="FONT FAMILY" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding FontFamily}"
                                  Margin="0,0,0,8"
                                  FontSize="11" Width="230" HorizontalAlignment="Left">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="SIZE" Style="{StaticResource SectionLabel}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}" Width="90" />
                            <xctk:IntegerUpDown Value="{Binding FontSize}" Minimum="2" Maximum="64" Width="55" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" />

                        <TextBlock Text="FOOTER TEXT" Style="{StaticResource PanelHeader}" />

                        <TextBlock Text="FONT FAMILY" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding FooterFontFamily}"
                                  Margin="0,0,0,8"
                                  FontSize="11" Width="230" HorizontalAlignment="Left">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="SIZE" Style="{StaticResource SectionLabel}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}" Width="90" />
                            <xctk:IntegerUpDown Value="{Binding FooterFontSize}" Minimum="2" Maximum="64" Width="55" />
                        </StackPanel>

                        <Separator Style="{StaticResource Separator}" />

                        <TextBlock Text="IN GAME TIME" Style="{StaticResource PanelHeader}" />

                        <TextBlock Text="FONT FAMILY" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding IgtFontFamily}"
                                  Margin="0,0,0,8"
                                  FontSize="11" Width="230" HorizontalAlignment="Left">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="SIZE" Style="{StaticResource SectionLabel}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}" Width="90" />
                            <xctk:IntegerUpDown Value="{Binding IgtFontSize}" Minimum="2" Maximum="64" Width="55" />
                        </StackPanel>

                        <TextBlock Text="RUN COMPLETION" Style="{StaticResource PanelHeader}" />

                        <TextBlock Text="RUN COMPLETION MESSAGE" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding RunCompleteText, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                 Margin="0,0,0,8" Width="230" HorizontalAlignment="Left" />


                        <Separator Style="{StaticResource Separator}" />

                        <TextBlock Text="STYLE" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="Applies to all but title and run completion." FontSize="10" FontStyle="Italic"
                                   Foreground="#878686" Margin="0,-4,0,4" />
                        <CheckBox Content="Bold" IsChecked="{Binding FontBold}" Margin="0,3,0,3" />
                        <CheckBox Content="Italic" IsChecked="{Binding FontItalic}" Margin="0,3,0,3" />
                        <CheckBox Content="Underline" IsChecked="{Binding FontUnderline}" Margin="0,3,0,3" />


                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" BorderBrush="#2a2a2a" BorderThickness="0,1,0,0" Padding="8,6">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Reset to Defaults" Command="{Binding ResetToDefaultsCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Cancel_Click" Margin="0,0,6,0" />
                    <Button Command="{Binding SaveCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="Save" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirty}" Value="False">
                                        <Setter Property="Content" Value="Saved ✓" />
                                        <Setter Property="Foreground" Value="#4a9a4a" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>